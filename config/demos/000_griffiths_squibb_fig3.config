{
  "format": "wspradar.config",
  "schema_version": 1,
  "profile": {
    "id": "griffiths_squibb_fig3",
    "title": {
      "en": "Prof. Griffiths (G3ZIL) et al. RX Comparison: Low Dipole vs Radial-Free Vertical."
    },
    "description": {
      "en": "[Publication: Griffiths, G., & Squibb, N. J. (2017). Improving HF band SNR from analysis of WSPR spots](https://www.researchgate.net/publication/319903566_Improving_HF_Band_SNR_from_analysis_of_WSPR_spots) \n\n Re-examines Griffiths & Squibb Fig. 3 using reports of the same transmitter in the same WSPR cycle at G3ZIL and G4HZX.  In RX Compare → Segment Insight, the chronological ΔSNR (G3ZIL low dipole − G4HZX radial-free vertical) distribution shifts, consistent with the paper’s drying-soil hypothesis."
    }
  },
  "settings": {
    "core_parameters": {
      "analysis_direction": "rx",
      "callsign": "G3ZIL",
      "qth": "IO90HW",
      "band": "40m",
      "time_selection": {
        "mode": "custom",
        "start_date": "2017-04-01",
        "end_date": "2017-05-01",
        "start_time_utc": "00:00",
        "end_time_utc": "00:00"
      }
    },
    "comparison_parameters": {
      "mode": "reference_station",
      "snr_correction_db": 0.0,
      "reference_callsign": "G4HZX",
      "reference_qth": "IO91"
    },
    "advanced_parameters": {
      "solar_state": "all",
      "max_peer_distance_km": 10000,
      "exclude_special_callsigns": false,
