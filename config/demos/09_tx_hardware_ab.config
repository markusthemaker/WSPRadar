{
  "format": "wspradar.config",
  "schema_version": 1,
  "profile": {
    "id": "tx_hardware_ab",
    "title": {
      "en": "TX hardware A/B test",
      "de": "TX Hardware-A/B-Test"
    },
    "description": {
      "en": "Runs a scheduled sequential TX A/B demo for DL1MKS on 20m with a 4-minute repeat interval and starts at 00 and 02 UTC.",
      "de": "Fuehrt eine geplante sequenzielle TX-A/B-Demo fuer DL1MKS auf 20 m mit 4-Minuten-Wiederholintervall und Starts um 00 und 02 UTC aus."
    }
  },
  "settings": {
    "core_parameters": {
      "analysis_direction": "tx",
      "callsign": "DL1MKS",
      "qth": "JN37",
      "band": "20m",
      "time_selection": {
        "mode": "custom",
        "start_date": "2026-03-27",
        "end_date": "2026-03-31",
        "start_time_utc": "00:00",
        "end_time_utc": "00:00"
      }
    },
    "comparison_parameters": {
      "mode": "hardware_ab",
      "tx_ab_method": "sequential",
      "repeat_interval_minutes": 4,
      "target_start_minute": 0,
      "reference_start_minute": 2,
      "snr_correction_mode": "no_offset",
      "snr_correction_db": 0.0
    },
    "advanced_parameters": {
      "solar_state": "all",
      "max_peer_distance_km": 22000,
      "exclude_special_callsigns": false,
      "exclude_moving_stations": false,
      "min_joint_spots_per_station": 1,
      "min_confirmed_opportunities_per_peer": 5,
      "min_joint_stations_per_map_segment": 1
    },
    "results_view": {
      "success": {
        "selected_ranges": "all",
        "selected_directions": "all",
        "show_zero_target": false,
        "station_evidence_time_bin": "3h",
        "selected_stations": null
      },
      "compare": {
        "selected_ranges": "all",
        "selected_directions": "all",
        "show_non_joint": false,
        "segment_evidence_time_bin": "auto",
        "station_evidence_time_bin": "3h",
        "station_evidence_temporal_view": "chronological",
        "selected_stations": null
      }
    }
  },
  "extensions": {}
}
