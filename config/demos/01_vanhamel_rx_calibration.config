{
  "format": "wspradar.config",
  "schema_version": 1,
  "profile": {
    "id": "vanhamel_rx_calibration",
    "title": {
      "en": "Dr. Vanhamel et al. RX Chain Calibration: Calibrating a 1.2 dB Receiver Offset"
    },
    "description": {
      "en": "[Publication: Vanhamel, J., Machiels, W., & Lamy, H. (2022). Using the WSPR Mode for Antenna Performance Evaluation and Propagation Assessment on the 160-m Band](https://doi.org/10.1155/2022/4809313)\n\nReplays the dual-receiver calibration with both ON4AWM chains connected to the same antenna and no SNR correction applied. Same-cycle joint reports average +1.2 dB for ON4AWM0 − ON4AWM1; the four transmitters passing the ≥50-joint-report threshold each have a +1.0 dB median. This is consistent with the paper’s 1.2 dB receiver-chain offset and establishes the correction used in the antenna experiment."
    }
  },
  "settings": {
    "core_parameters": {
      "analysis_direction": "rx",
      "callsign": "ON4AWM0",
      "qth": "JO20OT",
      "band": "160m",
      "time_selection": {
        "mode": "custom",
        "start_date": "2021-02-09",
        "end_date": "2021-02-13",
        "start_time_utc": "22:00",
        "end_time_utc": "05:30"
      }
    },
    "comparison_parameters": {
      "mode": "hardware_ab",
      "reference_callsign": "ON4AWM1",
      "snr_correction_db": 0.0
    },
    "advanced_parameters": {
      "solar_state": "all",
      "max_peer_distance_km": 2500,
      "exclude_special_callsigns": false,
      "exclude_moving_stations": false,
      "min_joint_spots_per_station": 50,
      "min_confirmed_opportunities_per_peer": 5,
      "min_joint_stations_per_map_segment": 1
    },
    "results_view": {
      "success": {
        "selected_ranges": "all",
        "selected_directions": "all",
        "show_zero_target": false,
        "station_evidence_time_bin": "6h",
        "selected_stations": null
      },
      "compare": {
        "selected_ranges": "all",
        "selected_directions": "all",
        "show_non_joint": false,
        "segment_evidence_time_bin": "auto",
        "station_evidence_time_bin": "6h",
        "station_evidence_temporal_view": "chronological",
        "selected_stations": null
      }
    }
  },
  "extensions": {}
}
