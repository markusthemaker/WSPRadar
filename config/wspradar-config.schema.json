      ]
    },
    "advancedParametersNoComparison": {
      "type": "object",
      "description": "Advanced controls active when comparison mode is none.",
      "required": [
        "solar_state",
        "map_scope_km",
        "exclude_special_callsigns",
        "exclude_moving_stations",
        "min_confirmed_opportunities_per_peer",
        "min_joint_stations_per_map_segment"
      ],
      "properties": {
        "solar_state": {
          "$ref": "#/$defs/solarState"
        },
        "map_scope_km": {
          "$ref": "#/$defs/mapScopeKm"
        },
        "exclude_special_callsigns": {
          "$ref": "#/$defs/excludeSpecialCallsigns"
        },
        "exclude_moving_stations": {
          "$ref": "#/$defs/excludeMovingStations"
        },
        "min_confirmed_opportunities_per_peer": {
          "$ref": "#/$defs/minConfirmedOpportunitiesPerPeer"
        },
        "min_joint_stations_per_map_segment": {
          "$ref": "#/$defs/minJointStationsPerMapSegment"
        }
      },
      "additionalProperties": false
    },
    "advancedParametersWithComparison": {
      "type": "object",
      "description": "Advanced controls active for hardware A/B, reference-station, and local-neighborhood comparisons.",
      "required": [
        "solar_state",
        "map_scope_km",
        "exclude_special_callsigns",
        "exclude_moving_stations",
        "min_joint_spots_per_station",
        "min_confirmed_opportunities_per_peer",
        "min_joint_stations_per_map_segment"
      ],
      "properties": {
        "solar_state": {
          "$ref": "#/$defs/solarState"
        },
        "map_scope_km": {
          "$ref": "#/$defs/mapScopeKm"
        },
        "exclude_special_callsigns": {
          "$ref": "#/$defs/excludeSpecialCallsigns"
        },
        "exclude_moving_stations": {
          "$ref": "#/$defs/excludeMovingStations"
        },
        "min_joint_spots_per_station": {
          "$ref": "#/$defs/minJointSpotsPerStation"
        },
        "min_confirmed_opportunities_per_peer": {
          "$ref": "#/$defs/minConfirmedOpportunitiesPerPeer"
        },
        "min_joint_stations_per_map_segment": {
          "$ref": "#/$defs/minJointStationsPerMapSegment"
        }
      },
      "additionalProperties": false
    },
    "solarState": {
      "type": "string",
      "enum": [
        "all",
        "day",
        "night",
        "greyline"
      ],
      "description": "Local target-QTH solar-state filter.",
      "default": "all",
      "examples": [
        "all",
        "day",
        "night",
        "greyline"
      ]
    },
    "mapScopeKm": {
      "type": "integer",
      "enum": [
        2500,
        5000,
        10000,
        15000,
        20000,
        22000
      ],
      "description": "Maximum map distance from the target QTH, in kilometres.",
      "default": 22000,
      "examples": [
        2500,
        10000,
        22000
      ]
    },
    "excludeSpecialCallsigns": {
      "type": "boolean",
      "description": "Whether to exclude special callsigns ending in Q, 0, or 1.",
      "default": false
    },
    "excludeMovingStations": {
      "type": "boolean",
      "description": "Whether to exclude callsigns observed at more than one locator.",
      "default": false
    },
    "minJointSpotsPerStation": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "description": "Minimum number of joint target/reference spots required per station.",
      "default": 1
    },
    "minConfirmedOpportunitiesPerPeer": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Minimum number of target-plus-counter evidence opportunities required per peer.",
      "default": 5
    },
    "minJointStationsPerMapSegment": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "Minimum number of qualifying stations required for a map segment.",
      "default": 1
    },
    "resultsViewNoComparison": {
      "type": "object",
      "description": "Durable Success-result view state active when comparison mode is none.",
      "required": [
        "success"
      ],
      "properties": {
        "success": {
          "$ref": "#/$defs/successResultsView"
        }
      },
      "additionalProperties": false
    },
    "resultsViewWithComparison": {
      "type": "object",
      "description": "Durable Compare and Success result-view state active for comparison analyses.",
      "required": [
        "success",
        "compare"
      ],
      "properties": {
        "success": {
          "$ref": "#/$defs/successResultsView"
        },
        "compare": {
          "$ref": "#/$defs/compareResultsView"
        }
      },
      "additionalProperties": false
    },
    "successResultsView": {
      "type": "object",
      "description": "Success station-insight state.",
      "required": [
        "selected_ranges",
        "selected_directions",
        "show_zero_target",
        "station_evidence_time_bin",
        "selected_stations"
      ],
      "properties": {
        "selected_ranges": {
          "$ref": "#/$defs/selectedSegmentRanges"
        },
        "selected_directions": {
          "$ref": "#/$defs/selectedSegmentDirections"
        },
        "show_zero_target": {
          "type": "boolean",
          "description": "Whether Success Station Insights includes qualifying stations with zero Target confirmations.",
          "default": false
        },
        "station_evidence_time_bin": {
          "$ref": "#/$defs/evidenceTimeBin"
        },
        "selected_stations": {
          "$ref": "#/$defs/selectedStations"
        }
      },
      "additionalProperties": false
    },
    "compareResultsView": {
      "type": "object",
      "description": "Compare segment and station-insight state.",
      "required": [
        "selected_ranges",
        "selected_directions",
        "show_non_joint",
        "segment_evidence_time_bin",
        "station_evidence_time_bin",
        "station_evidence_temporal_view",
        "selected_stations"
      ],
      "properties": {
        "selected_ranges": {
          "$ref": "#/$defs/selectedSegmentRanges"
        },
        "selected_directions": {
          "$ref": "#/$defs/selectedSegmentDirections"
        },
        "show_non_joint": {
          "type": "boolean",
          "description": "Whether station evidence includes non-joint observations in comparison views.",
          "default": false
        },
        "segment_evidence_time_bin": {
          "$ref": "#/$defs/segmentEvidenceTimeBin"
        },
        "station_evidence_time_bin": {
          "$ref": "#/$defs/evidenceTimeBin"
        },
        "station_evidence_temporal_view": {
          "$ref": "#/$defs/stationEvidenceTemporalView"
        },
        "selected_stations": {
          "$ref": "#/$defs/selectedStations"
        }
      },
      "additionalProperties": false
    },
    "evidenceTimeBin": {
      "type": "string",
      "enum": [
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "3h",
        "6h",
        "12h",
        "24h"
      ],
      "description": "Time-bin width for station-evidence plots.",
      "default": "3h",
      "examples": [
        "5m",
        "3h",
        "24h"
      ]
    },
    "segmentEvidenceTimeBin": {
      "type": "string",
      "enum": [
        "auto",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "3h",
        "6h",
        "12h",
        "24h"
      ],
      "description": "Time-bin width for the Compare segment temporal plot. auto retains automatic selection.",
      "default": "auto",
      "examples": [
        "auto",
        "3h",
        "24h"
      ]
    },
    "stationEvidenceTemporalView": {
      "type": "string",
      "enum": [
        "chronological",
        "utc_hour"
      ],
      "description": "Whether the Compare station temporal plot uses chronological time or folds observations into UTC-hour bins.",
      "default": "chronological"
    },
    "selectedSegmentRanges": {
      "description": "Selected Segment Inspector distance ranges. all selects every currently available range; an array records one or more canonical range labels.",
      "oneOf": [
        {
          "const": "all"
        },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "[0-2500km]",
              "[2500-5000km]",
              "[5000-10000km]",
              "[10000-15000km]",
              "[15000-20000km]",
              "[20000-22000km]"
            ]
          }
        }
      ]
    },
    "selectedSegmentDirections": {
      "description": "Selected Segment Inspector compass directions. all selects every currently available direction; an array records one or more canonical compass identifiers.",
      "oneOf": [
        {
          "const": "all"
        },
        {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "N",
              "NNE",
              "NE",
              "ENE",
              "E",
              "ESE",
              "SE",
              "SSE",
              "S",
              "SSW",
              "SW",
              "WSW",
              "W",
              "WNW",
              "NW",
              "NNW"
            ]
          }
        }
      ]
    },
    "selectedStations": {
      "description": "Station-selection intent. null requests automatic selection; all selects every station in the reconstructed table; an array records the explicit ordered selection, including an empty selection.",
      "default": null,
      "oneOf": [
        {
          "type": "null"
        },
        {
          "const": "all"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/selectedStation"
          },
          "uniqueItems": true
        }
      ]
    },
    "selectedStation": {
      "type": "object",
      "description": "Stable station identity independent of table order or presentation labels.",
      "required": [
        "callsign",
        "locator"
      ],
      "properties": {
        "callsign": {
          "type": "string",
          "pattern": "^[A-Z0-9/]{3,15}$"
        },
        "locator": {
          "type": "string",
          "pattern": "^[A-R]{2}[0-9]{2}(?:[A-X]{2})?$"
        }
      },
      "additionalProperties": false
    }
  }
}
