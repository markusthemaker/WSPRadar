{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wspradar.org/schemas/guided-input-flow-v1.json",
  "title": "WSPRadar Guided Input Flow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "start_node",
    "terminal_node",
    "node_order",
    "nodes"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "start_node": {
      "$ref": "#/$defs/node_id"
    },
    "terminal_node": {
      "$ref": "#/$defs/node_id"
    },
    "node_order": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/node_id"
      }
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/node_id"
      },
      "additionalProperties": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "node_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "state_field": {
      "type": "string",
      "enum": [
        "guided_use_case",
        "analysis_direction",
        "callsign",
        "qth",
        "band",
        "time_mode",
        "benchmark_mode",
        "local_benchmark",
        "tx_ab_method",
        "snr_correction_mode",
        "guided_scope_mode"
      ]
    },
    "scalar": {
      "type": [
        "string",
        "number",
        "integer",
        "boolean",
        "null"
      ]
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "field",
            "equals"
          ],
          "properties": {
            "field": {
              "$ref": "#/$defs/state_field"
            },
            "equals": {
              "$ref": "#/$defs/scalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "field",
            "in"
          ],
          "properties": {
            "field": {
              "$ref": "#/$defs/state_field"
            },
            "in": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/scalar"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/condition"
            }
          }
        }
      ]
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "when",
        "next"
      ],
      "properties": {
        "when": {
          "$ref": "#/$defs/condition"
        },
        "next": {
          "$ref": "#/$defs/node_id"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_key",
        "renderer",
        "summary_renderer",
        "required_fields",
        "transitions"
      ],
      "properties": {
        "content_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
        },
        "renderer": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "summary_renderer": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "required_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/state_field"
          }
        },
        "skip_when": {
          "$ref": "#/$defs/condition"
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transition"
          }
        }
      }
    }
  }
}
